# Set default behavior to automatically normalize line endings.
* text=auto
*.c text
*.h text
*.hpp text
*.cc text eol=lf
*.cxx text eol=lf
*.cpp text eol=lf
*.idl text eol=lf
*.json text eol=lf
*.js text eol=lf
*.ts text eol=lf

/assets/*.txt eol=crlf
*.iss eol=crlf
*.dlg eol=crlf

# .chm files
*.chm text eol=crlf
*.htm text eol=crlf
*.hhc text eol=crlf
*.hhk text eol=crlf
*.hhp text eol=crlf

# Build system Files
*.py text
*.gn text
*.gni text
*.mak text eol=lf
*.diff text eol=lf
*.patch text eol=lf

# Keep scripts correct
*.sh text eol=lf
*.bat text eol=crlf
*.cmd text eol=crlf
*.rc text eol=crlf
